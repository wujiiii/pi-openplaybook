{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"lib": ["ES2024", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"rewriteRelativeImportExtensions": false,
		"skipLibCheck": true,
		"types": ["vite/client"]
	},
	"include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
